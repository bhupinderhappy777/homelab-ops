# Generated by Ansible
# Shared Variables
TZ={{ tz | default('America/Vancouver') }}
ADMIN_USER={{ admin_username | default('deployuser') }}

# Credentials from Azure Key Vault (role keyvault_secrets sets vault_* facts).

# DB Passwords & Credentials
COUCHDB_USER={{ vault_couchdb_user }}
COUCHDB_PASSWORD={{ vault_couchdb_password }}
DOCUSEAL_POSTGRES_PASSWORD={{ vault_docuseal_postgres_password }}
FIREFLY_APP_KEY={{ vault_firefly_app_key }}
FIREFLY_DB_PASSWORD={{ vault_firefly_db_password }}
FIREFLY_CRON_TOKEN={{ vault_firefly_cron_token }}
IMMICH_DB_PASSWORD={{ vault_immich_db_password }}
MONICA_DB_PASSWORD={{ vault_monica_db_password }}
MONICA_APP_KEY={{ vault_monica_app_key if (vault_monica_app_key | default('') | regex_search('^base64:')) else 'base64:' ~ vault_monica_app_key }}
GRAFANA_PASSWORD={{ vault_grafana_password }}
OPENWEBUI_SECRET_KEY={{ vault_openwebui_secret_key }}
PAPERLESS_DB_USER={{ vault_paperless_db_user }}
PAPERLESS_DB_PASSWORD={{ vault_paperless_db_password }}
PIHOLE_PASSWORD={{ vault_pihole_password }}

# Stack URLs / hosts
DOCUSEAL_HOST={{ docuseal_host | default('docuseal.example.com') }}
FIREFLY_APP_URL={{ firefly_app_url | default('https://firefly.example.com') }}
GRAFANA_ROOT_URL={{ grafana_root_url | default('http://grafana.example.com:3005') }}
MONICA_APP_URL={{ monica_app_url | default('http://monica.example.com:8080') }}
N8N_WEBHOOK_URL={{ n8n_webhook_url | default('https://n8n.example.com') }}
N8N_IMAGE={{ n8n_image | default('docker.io/n8nio/n8n:latest') }}
OPENWEBUI_URL={{ openwebui_url | default('https://openwebui.example.com') }}
PAPERLESS_URL={{ paperless_url | default('https://paperless.example.com') }}
PAPERLESS_ALLOWED_HOSTS={{ paperless_allowed_hosts | default('paperless.example.com,localhost,127.0.0.1') }}

# Paths
DATA_ROOT=/opt/homelab/data
MEDIA_ROOT=/opt/homelab/media
CONTAINER_SOCKET_PATH={{ container_socket_path | default('/var/run/docker.sock') }}
