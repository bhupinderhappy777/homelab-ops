# Generated by Ansible
# Shared Variables
TZ={{ tz | default('America/Vancouver') }}
ADMIN_USER={{ admin_username | default('deployuser') }}

# Credentials from Azure Key Vault (role keyvault_secrets sets vault_* facts).

# DB Passwords & Credentials
COUCHDB_USER={{ vault_couchdb_user }}
COUCHDB_PASSWORD={{ vault_couchdb_password }}
DOCUSEAL_POSTGRES_PASSWORD={{ vault_docuseal_postgres_password }}

# Firefly

FIREFLY_APP_KEY={{ vault_firefly_app_key }}
FIREFLY_DB_PASSWORD={{ vault_firefly_db_password }}
FIREFLY_CRON_TOKEN={{ vault_firefly_cron_token }}
FIREFLY_AUTHENTICATION_GUARD=remote_user_guard
FIREFLY_AUTHENTICATION_GUARD_HEADER=HTTP_X_AUTHENTIK_EMAIL
FIREFLY_AUTHENTICATION_GUARD_EMAIL=HTTP_X_AUTHENTIK_EMAIL


IMMICH_DB_PASSWORD={{ vault_immich_db_password }}
MONICA_DB_PASSWORD={{ vault_monica_db_password }}
MONICA_DB_USER=monica
MONICA_DB_NAME=monica
MONICA_APP_KEY={{ vault_monica_app_key if (vault_monica_app_key | default('') | regex_search('^base64:')) else 'base64:' ~ vault_monica_app_key }}
GRAFANA_PASSWORD={{ vault_grafana_password }}
OPENWEBUI_SECRET_KEY={{ vault_openwebui_secret_key }}
PIHOLE_PASSWORD={{ vault_pihole_password }}
TRANSMISSION_RPC_PASSWORD={{ vault_transmission_rpc_password }}

# Stack URLs / hosts
DOCUSEAL_HOST={{ docuseal_host }}
FIREFLY_APP_URL={{ firefly_app_url }}
GRAFANA_ROOT_URL={{ grafana_root_url}}
MONICA_APP_URL={{ monica_app_url }}
N8N_WEBHOOK_URL={{ n8n_webhook_url  }}
N8N_IMAGE={{ n8n_image }}
OPENWEBUI_URL={{ openwebui_url  }}


# Paths
DATA_ROOT=/opt/homelab/data
MEDIA_ROOT=/opt/homelab/media
CONTAINER_SOCKET_PATH={{ container_socket_path | default('/var/run/docker.sock') }}

# Authentik Email Settings
AUTHENTIK_EMAIL__HOST=smtp.gmail.com
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME= {{ vault_authentik_email_username }}
AUTHENTIK_EMAIL__PASSWORD={{ vault_authentik_email_password }}
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=30
COMPOSE_PORT_HTTP=9009
COMPOSE_PORT_HTTPS=9446

#Grafana
GRAFANA_ROOT_URL=https://grafana.bhupindergill.ca/
GRAFANA_PASSWORD= {{ vault_grafana_password }}
GF_AUTH_GENERIC_OAUTH_ENABLED="true"
GF_AUTH_GENERIC_OAUTH_NAME="authentik"
GF_AUTH_GENERIC_OAUTH_CLIENT_ID="LLF9sSAd3ZN8n6yKnPwkMUdG9gAVfNbA5pXVZzhc"
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET="{{ vault_grafana_oauth_client_secret }}"
GF_AUTH_GENERIC_OAUTH_SCOPES="openid profile email"
GF_AUTH_GENERIC_OAUTH_AUTH_URL="https://authentik.bhupindergill.ca/application/o/authorize/"
GF_AUTH_GENERIC_OAUTH_TOKEN_URL="https://authentik.bhupindergill.ca/application/o/token/"
GF_AUTH_GENERIC_OAUTH_API_URL="https://authentik.bhupindergill.ca/application/o/userinfo/"
GF_AUTH_SIGNOUT_REDIRECT_URL="https://authentik.bhupindergill.ca/application/o/grafana/end-session/"
# Optionally enable auto-login (bypasses Grafana login screen)
GF_AUTH_OAUTH_AUTO_LOGIN="true"
# Required if Grafana is running behind a reverse proxy
GF_SERVER_ROOT_URL="https://grafana.bhupindergill.ca/"

PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect
PAPERLESS_SOCIALACCOUNT_PROVIDERS= {{ vault_paperless_socialaccount_providers }}
PAPERLESS_LOGOUT_REDIRECT_URL=https://authentik.bhupindergill.ca/application/o/paperless/end-session/
PAPERLESS_SOCIAL_AUTO_SIGNUP=true
PAPERLESS_SOCIALACCOUNT_ALLOW_SIGNUPS=true
PAPERLESS_URL={{ paperless_url  }}
PAPERLESS_ALLOWED_HOSTS={{ paperless_allowed_hosts }}
PAPERLESS_DB_PASSWORD={{ vault_paperless_db_password }}
