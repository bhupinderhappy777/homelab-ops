# Example only — production `.env` is rendered on the VM by Ansible from Azure Key Vault.
# See ansible/roles/docker_stacks_deploy/templates/homelab.env.j2 and root README.md.

TZ=America/Vancouver
ADMIN_USER=deployuser

CLOUDFLARE_TUNNEL_TOKEN=placeholder_token

COUCHDB_USER=deployuser
COUCHDB_PASSWORD=changeme
DOCUSEAL_POSTGRES_PASSWORD=changeme
FIREFLY_APP_KEY=SomeRandomStringOf32CharsExactly
FIREFLY_DB_PASSWORD=changeme
FIREFLY_CRON_TOKEN=changeme
IMMICH_DB_PASSWORD=changeme
MONICA_DB_PASSWORD=changeme
MONICA_APP_KEY=base64:changeme
GRAFANA_PASSWORD=changeme
OPENWEBUI_SECRET_KEY=changeme
PAPERLESS_DB_USER=paperless_user
PAPERLESS_DB_PASSWORD=changeme
PIHOLE_PASSWORD=changeme

DOCUSEAL_HOST=docuseal.example.com
FIREFLY_APP_URL=https://firefly.example.com
GRAFANA_ROOT_URL=http://grafana.example.com:3005
MONICA_APP_URL=http://monica.example.com:8080
N8N_WEBHOOK_URL=https://n8n.example.com
N8N_IMAGE=docker.io/n8nio/n8n:latest
OPENWEBUI_URL=https://openwebui.example.com
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_ALLOWED_HOSTS=paperless.example.com,localhost,127.0.0.1

DATA_ROOT=/opt/homelab/data
MEDIA_ROOT=/opt/homelab/media
CONTAINER_SOCKET_PATH=/var/run/docker.sock

# --- Optional: values you may also set in Key Vault for backup/restic (see docs/README.md) ---
# RESTIC_PASSWORD=
# OCI_S3_ACCESS_KEY_ID=
# OCI_S3_SECRET_ACCESS_KEY=
# OCI_S3_BUCKET=
# OCI_S3_ENDPOINT=
# TAILSCALE_AUTH_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
